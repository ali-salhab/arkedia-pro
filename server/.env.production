PORT=5000
MONGO_URI=mongodb+srv://arkedia_user:YOUR_PASSWORD@arkedia-cluster.xxxxx.mongodb.net/booking_platform?retryWrites=true&w=majority
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_LONG_RANDOM_REFRESH_SECRET_MIN_32_CHARS
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
CLIENT_ORIGIN=https://yourdomain.com
